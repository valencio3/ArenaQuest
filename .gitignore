# ==============================================================================
# ArenaQuest — .gitignore
# Stack: Node.js · TypeScript · Next.js · Cloudflare Workers · pnpm · Turborepo
# ==============================================================================

# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/

# ── Build outputs ──────────────────────────────────────────────────────────────
# Next.js
.next/
out/

# Cloudflare Workers / Wrangler
dist/
.wrangler/

# TypeScript
*.tsbuildinfo

# ── Turborepo ──────────────────────────────────────────────────────────────────
.turbo/

# ── Environment variables ──────────────────────────────────────────────────────
# Never commit secrets. Use .env.example for documentation.
.env
.env.*
!.env.example
!.env.*.example
# Cloudflare Workers local secrets (wrangler dev / vitest)
.dev.vars
!.dev.vars.example

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test & coverage ────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# Vitest
vitest.results.*

# ── OS artefacts ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ───────────────────────────────────────────────────────────────
# VS Code (keep .vscode/extensions.json and .vscode/settings.json if desired)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains IDEs
.idea/

# Cursor AI
.cursorignore
.cursorindexingignore

# ── pnpm ───────────────────────────────────────────────────────────────────────
# pnpm-lock.yaml is intentionally committed for reproducible installs.
# Do NOT add it here.

# ── Miscellaneous ──────────────────────────────────────────────────────────────
*.tgz
*.zip
.cache/
tmp/
temp/
