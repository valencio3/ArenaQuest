{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "API: Launch (Wrangler)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "--filter",
                "api",
                "dev",
                "--",
                "--inspector-port",
                "9229"
            ],
            "cwd": "${workspaceFolder}/apps/api",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ]
        },
        {
            "name": "API: Attach",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "cwd": "${workspaceFolder}/apps/api",
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/apps/api/.wrangler/**",
                "!**/node_modules/**"
            ]
        },
        {
            "name": "Web: Debug (Next.js)",
            "type": "node-terminal",
            "request": "launch",
            "command": "pnpm --filter web dev",
            "cwd": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: Debug",
            "configurations": [
                "API: Launch (Wrangler)",
                "Web: Debug (Next.js)"
            ]
        }
    ]
}