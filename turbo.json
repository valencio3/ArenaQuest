{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs:er": {
      "inputs": ["packages/shared/types/**/*.ts", "docs/templates/entity-schema.mmd"],
      "outputs": ["docs/entities.svg"]
    }
  }
}
